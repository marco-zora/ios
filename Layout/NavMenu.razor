@inject NavigationManager Nav
@inject BlazorApp_IOS.Shared.GlobalService Global
@implements IDisposable






<!-- <div class="nav-menu px-3 py-2"> -->

    <div class="nav-sidebar">

    <div class="sidebar-logo">
        <img src="images/logo.png" alt="Logo" />
    </div>
    
<nav class="sidebar-nav">
        <ul class="nav flex-column">

   
    @if (!IsLoggedIn)
    {
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Login
            </NavLink>
        </div>
    }
    else
    {
        <div class="text-muted mb-2">
            Utente: @LoggedUser
            @if (IsAdmin)
            {
                <span>(admin)</span>
            }
        </div>

        @if (IsAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="clienti">Clienti</NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="impianti">Impianti</NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="impianti">I miei impianti</NavLink>
            </div>
        }

         <div class="nav-item px-3">
            <a class="nav-link logout"
               href="#"
               @onclick="Logout"
               @onclick:preventDefault="true"
               @onclick:stopPropagation="true">

                  <svg class="logout-icon"
                     width="20"
                     height="20"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="1.5"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     style="flex-shrink:0">
                    <path d="M15 3h2a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4h-2" />
                    <path d="M10 17l5-5-5-5" />
                    <path d="M15 12H3" />
                </svg>
            <span>Logout</span>
            </a>
        </div>

    }


    <div class="nav-item px-3">
        <NavLink class="nav-link" href="home">
            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Home
        </NavLink>
    </div>
        </ul>
    </nav>


</div>

@code {
    private string? LoggedUser;
    private string? LoggedRole;

    private bool IsLoggedIn => !string.IsNullOrWhiteSpace(LoggedUser);
    private bool IsAdmin => string.Equals(LoggedRole, "admin", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Global.AuthChanged += OnAuthChanged;

        // stato iniziale (se l'utente era già loggato)
        await RefreshAuthStateAsync();
    }

    private async Task RefreshAuthStateAsync()
    {
        LoggedUser = await Global.LoggedUser();
        LoggedRole = await Global.LoggedRole();
    }

    private async void OnAuthChanged()
    {
        // IMPORTANTISSIMO: rileggere prima user/role, poi ridisegnare
        await RefreshAuthStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await Global.Logout();
        Nav.NavigateTo("login", forceLoad: true);  // ritorna alla pagina Home
    }

    public void Dispose()
    {
        Global.AuthChanged -= OnAuthChanged;
    }
}