@inject NavigationManager Nav
@inject BlazorApp_IOS.Shared.GlobalService Global
@implements IDisposable

<div class="nav-sidebar">

    <div class="sidebar-logo">
        <img src="images/HIDES-LOGO-2022_bianco-oriz.svg" alt="Logo" />
    </div>

    <nav class="sidebar-nav">
        <ul class="nav flex-column">

            @if (!IsLoggedIn)
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="login">
                        <span class="nav-icon">
                            <span class="bi bi-box-arrow-in-right"></span>
                        </span>
                        <span class="nav-label">Login</span>
                    </NavLink>
                </li>
            }
            else
            {
                <li class="sidebar-user">
                    <div class="user-name">@LoggedUser</div>
                    @if (IsAdmin)
                    {
                        <div class="user-role">Admin</div>
                    }
                </li>

                @if (IsAdmin)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin">
                            <span class="nav-icon">
                                <span class="bi bi-people"></span>
                            </span>
                            <span class="nav-label">Clienti</span>
                        </NavLink>
                    </li>

                    <li class="nav-item">
                        <NavLink class="nav-link" href="impianti">
                            <span class="nav-icon">
                                <span class="bi bi-diagram-3"></span>
                            </span>
                            <span class="nav-label">Impianti</span>
                        </NavLink>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="impianti">
                            <span class="nav-icon">
                                <span class="bi bi-diagram-3"></span>
                            </span>
                            <span class="nav-label">I miei Impianti</span>
                        </NavLink>
                    </li>
                }

                <li class="nav-item logout-item">
                    <a class="nav-link logout"
                       href="#"
                       @onclick="Logout"
                       @onclick:preventDefault="true"
                       @onclick:stopPropagation="true">

                        <span class="nav-icon">
                            <span class="bi bi-box-arrow-right"></span>
                        </span>

                        <span class="nav-label">Logout</span>
                    </a>
                </li>
            }

            <li class="nav-item">
                <NavLink class="nav-link" href="home">
                    <span class="nav-icon">
                        <span class="bi bi-house"></span>
                    </span>
                    <span class="nav-label">Home</span>
                </NavLink>
            </li>

        </ul>
    </nav>
</div>

@code {
    private string? LoggedUser;
    private string? LoggedRole;

    private bool IsLoggedIn => !string.IsNullOrWhiteSpace(LoggedUser);
    private bool IsAdmin => string.Equals(LoggedRole, "admin", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Global.AuthChanged += OnAuthChanged;
        await RefreshAuthStateAsync();
    }

    private async Task RefreshAuthStateAsync()
    {
        LoggedUser = await Global.LoggedUser();
        LoggedRole = await Global.LoggedRole();
    }

    private async void OnAuthChanged()
    {
        await RefreshAuthStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await Global.Logout();
        Nav.NavigateTo("login");
    }

    public void Dispose()
    {
        Global.AuthChanged -= OnAuthChanged;
    }
}