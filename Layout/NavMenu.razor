@inject NavigationManager Nav
@inject BlazorApp_IOS.Shared.GlobalService Global
@implements IDisposable

<div class="nav-sidebar">
    <!-- Header: logo + hamburger (hamburger visibile solo su mobile portrait via CSS) -->
    <div class="nav-header">
        <div class="sidebar-logo" @onclick="CloseMenu" role="button" tabindex="0" aria-label="Vai alla Home">
            <img src="images/HIDES-LOGO-2022_bianco-oriz.svg" alt="Logo" />
        </div>

        <button type="button"
                class="menu-toggle"
                aria-controls="mainNavPanel"
                aria-expanded="@menuOpen"
                aria-label="Apri/chiudi menu"
                @onclick="ToggleMenu">
            <span class="bi bi-list"></span>
        </button>
    </div>

    <!-- Backdrop: appare solo quando menu è aperto (mobile portrait) -->
    <div class="nav-backdrop @(menuOpen ? "show" : "")" @onclick="CloseMenu"></div>

    <!-- Panel: sidebar su desktop, drawer su mobile portrait -->
    <nav id="mainNavPanel" class="nav-panel @(menuOpen ? "open" : "")" aria-label="Navigazione principale">
        <ul class="nav-list">

            <!-- Home sempre disponibile -->
            <li class="nav-item">
                <NavLink class="nav-link" href="home" @onclick="CloseMenu">
                    <span class="nav-icon"><span class="bi bi-house"></span></span>
                    <span class="nav-label">Home</span>
                </NavLink>
            </li>

            @if (!IsLoggedIn)
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="login" @onclick="CloseMenu">
                        <span class="nav-icon"><span class="bi bi-box-arrow-in-right"></span></span>
                        <span class="nav-label">Login</span>
                    </NavLink>
                </li>
            }
            else
            {
                <li class="sidebar-user">
                    <div class="user-name">@LoggedUser</div>
                    @if (IsAdmin)
                    {
                        <div class="user-role">Admin</div>
                    }
                </li>

                @if (IsAdmin)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin" @onclick="CloseMenu">
                            <span class="nav-icon"><span class="bi bi-people"></span></span>
                            <span class="nav-label">Clienti</span>
                        </NavLink>
                    </li>

                    <li class="nav-item">
                        <NavLink class="nav-link" href="impianti" @onclick="CloseMenu">
                            <span class="nav-icon"><span class="bi bi-diagram-3"></span></span>
                            <span class="nav-label">Impianti</span>
                        </NavLink>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="impianti" @onclick="CloseMenu">
                            <span class="nav-icon"><span class="bi bi-diagram-3"></span></span>
                            <span class="nav-label">I miei Impianti</span>
                        </NavLink>
                    </li>
                }

                <li class="nav-item logout-item">
                    <button type="button" class="nav-link logout" @onclick="Logout">
                        <span class="nav-icon"><span class="bi bi-box-arrow-right"></span></span>
                        <span class="nav-label">Logout</span>
                    </button>
                </li>
            }
        </ul>
    </nav>
</div>

@code {
    private string? LoggedUser;
    private string? LoggedRole;

    private bool menuOpen;

    private bool IsLoggedIn => !string.IsNullOrWhiteSpace(LoggedUser);
    private bool IsAdmin => string.Equals(LoggedRole, "admin", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Global.AuthChanged += OnAuthChanged;
        await RefreshAuthStateAsync();
    }

    private async Task RefreshAuthStateAsync()
    {
        LoggedUser = await Global.LoggedUser();
        LoggedRole = await Global.LoggedRole();
    }

    private async void OnAuthChanged()
    {
        await RefreshAuthStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;

    private async Task Logout()
    {
        CloseMenu();
        await Global.Logout();
        Nav.NavigateTo("login");
    }

    public void Dispose()
    {
        Global.AuthChanged -= OnAuthChanged;
    }
}